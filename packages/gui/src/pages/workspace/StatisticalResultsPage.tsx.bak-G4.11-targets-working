type ManifestOutput = {
  relpath?: string;
  bytes?: number;
  checksum?: {
    alg?: string;
    value?: string;
  };
};

type ManifestResponse = {
  manifest?: {
    outputs?: ManifestOutput[];
    producer?: {
      tool_id?: string;
      tool_version?: string;
    };
  };
};

type Row = Record<string, unknown>;

type ExpandedChartState = {
  title: string;
  content: ReactNode;
} | null;

function isScalarValue(value: unknown): boolean {
  return (
    value == null ||
    typeof value === "string" ||
    typeof value === "number" ||
    typeof value === "boolean"
  );
}

function formatCellValue(value: unknown, column?: string): React.ReactNode {
  if (value == null) return "";

  // =========================
  // SESSION (COMPATTA)
  // =========================
  if (column === "session_calc") {
    const map: Record<string, string> = {
      ny: "NY",
      asia: "AS",
      europe: "EU",
      off: "OFF",
    };

    const label = map[String(value)] ?? String(value);

    return (
      <span
        style={{
          border: "1px solid rgba(255,255,255,0.15)",
          borderRadius: 999,
          padding: "2px 6px",
          fontSize: 11,
          opacity: 0.9,
          whiteSpace: "nowrap",
        }}
      >
        {label}
      </span>
    );
  }

  if (column === "breakout_price" && typeof value === "number") {
    return value.toLocaleString(undefined, {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    });
  }

  if (column === "breakout_time" && typeof value === "string") {
    const [date, time] = value.split("T");

    return (
      <div style={{ display: "flex", flexDirection: "column", lineHeight: 1.2 }}>
        <span style={{ fontSize: 12, opacity: 0.85 }}>{date}</span>
        <span style={{ fontSize: 11, opacity: 0.6 }}>
          {time?.slice(0, 5)}
        </span>
      </div>
    );
  }

  if (column === "delta_bucket") {
    const map: Record<string, string> = {
      delta_0_100: "Δ 0–100",
      delta_100_300: "Δ 100–300",
      delta_300_600: "Δ 300–600",
      delta_600_1000: "Δ 600–1000",
      delta_1000_plus: "Δ 1000+",
    };

    return map[String(value)] ?? String(value);
  }

  // =========================
  // EXCURSION / RETRACEMENT (UNIT)
  // =========================
  if (
    (column === "max_excursion" || column === "retracement_depth") &&
    typeof value === "number"
  ) {
    return `${value.toFixed(2)} pts`;
  }

  // =========================
  // WEEKDAY (SHORT)
  // =========================
  if (column === "weekday") {
    const map: Record<string, string> = {
      monday: "Mon",
      tuesday: "Tue",
      wednesday: "Wed",
      thursday: "Thu",
      friday: "Fri",
      saturday: "Sat",
      sunday: "Sun",
    };

    return map[String(value)] ?? String(value);
  }

  // =========================
  // SIDE (BADGE)
  // =========================
  if (column === "side") {
    const color =
      value === "long"
        ? "rgba(34,197,94,0.15)"
        : value === "short"
        ? "rgba(239,68,68,0.15)"
        : "rgba(255,255,255,0.08)";

    return (
      <span
        style={{
          padding: "2px 6px",
          borderRadius: 999,
          fontSize: 11,
          background: color,
          border: "1px solid rgba(255,255,255,0.12)",
          whiteSpace: "nowrap",
        }}
      >
        {String(value).toUpperCase()}
      </span>
    );
  }

  // =========================
  // OUTCOME (COLOR)
  // =========================
  if (column === "breakout_outcome") {
    const color =
      value === "true_breakout"
        ? "#22c55e"
        : value === "false_breakout"
        ? "#ef4444"
        : "#f59e0b";

    return (
      <span style={{ color, fontWeight: 500 }}>
        {String(value)}
      </span>
    );
  }

  // =========================
  // DEFAULT BEHAVIOR
  // =========================
  if (typeof value === "string") {
    return value.length > 120 ? `${value.slice(0, 117)}...` : value;
  }

  if (typeof value === "number") {
    return Number.isInteger(value) ? value : value.toFixed(2);
  }

  if (typeof value === "boolean") {
    return String(value);
  }

  if (Array.isArray(value)) {
    return `[list:${value.length}]`;
  }

  if (typeof value === "object") {
    return "[object]";
  }

  return String(value);
}

function pickPreviewColumns(rows: Row[]): string[] {
  const firstRow = rows[0];
  if (!firstRow) return [];

  const allColumns = Object.keys(firstRow);

  const priorityColumns = [
    "breakout_id",
    "breakout_time",
    "direction",
    "breakout_price",
    "breakout_outcome",
    "instrument",
    "side",
    "atr_before",
    "initial_delta",
    "delta_bucket",
    "initial_volume",
    "max_excursion",
    "retracement_depth",
    "session_calc",
    "weekday",
    "hour",
  ];

  const availablePriority = priorityColumns.filter((col) =>
    allColumns.includes(col)
  );

  const scalarFallback = allColumns.filter((col) =>
    rows.some((row) => isScalarValue(row[col]))
  );

  const merged = [...availablePriority];
  for (const col of scalarFallback) {
    if (!merged.includes(col)) {
      merged.push(col);
    }
  }

  return merged.slice(0, 15);
}

function groupBy(rows: any[], key: string) {
  const map: Record<string, any[]> = {};
  for (const row of rows) {
    const value = String(row[key] ?? "unknown");
    if (!map[value]) map[value] = [];
    map[value].push(row);
  }
  return map;
}

function formatDeltaBucketLabel(key: string) {
  if (key.includes("delta_")) {
    const parts = key.replace("delta_", "").split("_");

    if (parts.length === 2) {
      return `Δ ${parts[0]}–${parts[1]}`;
    }

    if (parts.length === 3 && parts[2] === "plus") {
      return `Δ ${parts[0]}+`;
    }
  }

  return key;
}

function formatVolumeBucketLabel(key: string) {
  return `Volume ${key}`;
}

function getDeltaSign(value: any) {
  const v = Number(value);
  if (isNaN(v)) return "unknown";
  if (v > 0) return "positive";
  if (v < 0) return "negative";
  return "neutral";
}

function distribution(rows: any[], key: string) {
  const groups = groupBy(rows, key);
  const total = rows.length;

  return Object.entries(groups)
    .map(([k, v]) => ({
      key: k,
      count: v.length,
      pct: total > 0 ? (v.length / total) * 100 : 0,
    }))
    .sort((a, b) => b.count - a.count);
}

function avg(rows: any[], field: string) {
  const values = rows
    .map((r) => Number(r[field]))
    .filter((v) => !isNaN(v));

  if (!values.length) return null;

  return values.reduce((a, b) => a + b, 0) / values.length;
}

function numericSummary(rows: any[], field: string) {
  const values = rows
    .map((r) => Number(r[field]))
    .filter((v) => !isNaN(v));

  if (!values.length) return null;

  return {
    avg: avg(rows, field),
    min: Math.min(...values),
    max: Math.max(...values),
  };
}

function detectTargetColumns(columns: string[]): string[] {
  return columns.filter((col) => {
    if (col === "is_clean_quant") return true;
    if (col.includes("_ATR")) return true;
    if (col.includes("_ticks")) return true;

    const lower = col.toLowerCase();
    if (lower.startsWith("t1")) return true;
    if (lower.startsWith("t2")) return true;

    return false;
  });
}

function cleanQuantRate(rows: any[]): number | null {
  const valid = rows
    .map((r) => r.is_clean_quant)
    .filter((v) => v !== null && v !== undefined);

  if (!valid.length) return null;

  const clean = valid.filter(
    (v) => v === true || v === "true" || v === 1
  ).length;

  return (clean / valid.length) * 100;
}

function isTruthyLabel(value: unknown): boolean {
  return value === true || value === "true" || value === 1;
}

function targetSuccessRate(rows: any[], column: string): number {
  if (!rows.length) return 0;

  const success = rows.filter((row) => isTruthyLabel(row[column])).length;
  return (success / rows.length) * 100;
}

function parseAtrScanLevel(column: string): number | null {
  const match = column.match(/_([0-9]+(?:_[0-9]+)?)ATR$/);
  if (!match) return null;
  return Number(match[1].replace("_", "."));
}

function parseTickScanLevel(column: string): number | null {
  const match = column.match(/_(\d+)ticks$/);
  if (!match) return null;
  return Number(match[1]);
}

function classifyTargetColumns(columns: string[]) {
  const atrScanColumns = columns
    .filter((column) => parseAtrScanLevel(column) !== null)
    .sort((a, b) => (parseAtrScanLevel(a) ?? 0) - (parseAtrScanLevel(b) ?? 0));

  const cleanTickColumns = columns
    .filter((column) => column.includes("_clean_") && parseTickScanLevel(column) !== null)
    .sort((a, b) => (parseTickScanLevel(a) ?? 0) - (parseTickScanLevel(b) ?? 0));

  const tickScanColumns = columns
    .filter(
      (column) =>
        !column.includes("_clean_") &&
        parseTickScanLevel(column) !== null
    )
    .sort((a, b) => (parseTickScanLevel(a) ?? 0) - (parseTickScanLevel(b) ?? 0));

  const cleanQuantColumns: string[] = columns.filter(
    (column) =>
      column === "is_clean_quant" ||
      column === "clean_quant_label"
  );

  const directTargetColumns = columns.filter(
    (column) =>
      !atrScanColumns.includes(column) &&
      !tickScanColumns.includes(column) &&
      !cleanTickColumns.includes(column) &&
      !cleanQuantColumns.includes(column)
  );

  return {
    directTargetColumns,
    atrScanColumns,
    tickScanColumns,
    cleanTickColumns,
    cleanQuantColumns,
  };
}

function buildTargetRateData(rows: any[], columns: string[]) {
  return columns.map((column) => ({
    name: column,
    value: Number(targetSuccessRate(rows, column).toFixed(1)),
  }));
}

function avgByGroup(rows: any[], groupKey: string, field: string) {
  const groups = groupBy(rows, groupKey);

  return Object.entries(groups).map(([k, v]) => ({
    key: k,
    avg: avg(v, field),
    count: v.length,
  }));
}

function groupByTwo(rows: any[], key1: string, key2: string) {
  const totalByGroup: Record<string, Record<string, number>> = {};

  rows.forEach((r) => {
    const k1 = String(r[key1] ?? "unknown");
    const k2 = String(r[key2] ?? "unknown");

    if (!totalByGroup[k1]) {
      totalByGroup[k1] = {};
    }

    totalByGroup[k1][k2] = (totalByGroup[k1][k2] ?? 0) + 1;
  });

  return Object.entries(totalByGroup).map(([k1, inner]) => {
    const total = Object.values(inner).reduce((a, b) => a + b, 0);

    return {
      key: k1,
      values: Object.entries(inner).map(([k2, count]) => ({
        key: k2,
        count,
        pct: total > 0 ? (count / total) * 100 : 0,
      })),
    };
  });
}

function groupByTwoKeys(rows: any[], key1: string, key2: string) {
  const map: Record<string, Record<string, any[]>> = {};

  rows.forEach((r) => {
    const k1 = String(r[key1] ?? "unknown");
    const k2 = String(r[key2] ?? "unknown");

    if (!map[k1]) map[k1] = {};
    if (!map[k1][k2]) map[k1][k2] = [];

    map[k1][k2].push(r);
  });

  return map;
}

function renderOutcomeValue(v: any) {
  const isBest = v.key === "true_breakout";
  const isWorst = v.key === "false_breakout";

  return (
    <div
      key={v.key}
      style={{
        paddingLeft: 8,
        color: isBest ? "#22c55e" : isWorst ? "#ef4444" : "#e5e7eb",
        fontWeight: isBest ? 600 : 400,
      }}
    >
      {v.key}: {v.count} ({v.pct.toFixed(1)}%)
    </div>
  );
}

function sortDeltaBuckets(a: string, b: string) {
  const order = [
    "delta_0_100",
    "delta_100_300",
    "delta_300_600",
    "delta_600_1000",
    "delta_1000_plus",
  ];

  return order.indexOf(a) - order.indexOf(b);
}

function sortVolumeBuckets(a: string, b: string) {
  const order = ["medium", "high", "extreme"];
  return order.indexOf(a) - order.indexOf(b);
}

function isRecord(value: unknown): value is Record<string, unknown> {
  return !!value && typeof value === "object" && !Array.isArray(value);
}



type BucketizersUsedResponse = {
  bucketizers?: Record<string, Record<string, number>>;
};

