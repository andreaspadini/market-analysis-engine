export function StatisticalResultsPage() {
  const { toolId, fingerprint } = useParams();
  const { http } = useApi();

  const [rows, setRows] = useState<Row[]>([]);
  const [relpath, setRelpath] = useState<string | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [bucketizersUsed, setBucketizersUsed] = useState<
    Record<string, Record<string, number>> | null
  >(null);
  const [expandedChart, setExpandedChart] = useState<ExpandedChartState>(null);

  const previewColumns = useMemo(() => pickPreviewColumns(rows), [rows]);
  const allColumns = useMemo(
    () => (rows[0] ? Object.keys(rows[0]) : []),
    [rows]
  );
  console.log("STATISTICAL RESULT COLUMNS", allColumns);

  const total = rows.length;

  const targetColumns = detectTargetColumns(allColumns);

  const {
    directTargetColumns,
    atrScanColumns,
    tickScanColumns,
    cleanTickColumns,
    cleanQuantColumns,
  } = classifyTargetColumns(targetColumns);

  const directTargetRateData = buildTargetRateData(rows, directTargetColumns);
  const atrScanRateData = buildTargetRateData(rows, atrScanColumns);
  const tickScanRateData = buildTargetRateData(rows, tickScanColumns);
  const cleanTickRateData = buildTargetRateData(rows, cleanTickColumns);

  const cleanQuantSummary =
    cleanQuantColumns.length > 0
      ? Number(targetSuccessRate(rows, cleanQuantColumns[0]).toFixed(1))
      : null;

  const maxExcursionSummary = numericSummary(rows, "max_excursion");
  const breakoutEfficiencySummary = numericSummary(rows, "breakout_efficiency");

  const avgMaxExcursion = maxExcursionSummary?.avg ?? null;
  const avgBreakoutEfficiency = breakoutEfficiencySummary?.avg ?? null;
  const cleanQuantPct = cleanQuantRate(rows);

  useEffect(() => {
    async function loadData() {
      if (!toolId || !fingerprint) {
        setError("Missing route parameters.");
        setLoading(false);
        return;
      }

      try {
        setLoading(true);
        setError(null);
        setBucketizersUsed(null);

        const manifestResponse = await http.get<ManifestResponse>(
          `/manifests/${toolId}/${fingerprint}`
        );

        const outputs = manifestResponse?.manifest?.outputs ?? [];

        const parquetOutput =
          outputs.find(
            (output) => output?.relpath === "outputs/statistical_dataset.parquet"
          ) ??
          outputs.find(
            (output) =>
              typeof output?.relpath === "string" &&
              output.relpath.endsWith(".parquet")
          );

        const resolvedRelpath = parquetOutput?.relpath;

        if (!resolvedRelpath || typeof resolvedRelpath !== "string") {
          throw new Error("Statistical parquet output not available in manifest.");
        }

        setRelpath(resolvedRelpath);

        const fileBuffer = await http.get<ArrayBuffer>(
          `/artifacts/${toolId}/${fingerprint}/${resolvedRelpath}`,
          { responseType: "arraybuffer" }
        );

        const parsedRows = await parquetReadObjects({
          file: fileBuffer,
        });

        setRows((parsedRows ?? []) as Row[]);

        const bucketizersOutput = outputs.find(
          (output) =>
            output?.relpath === "outputs/statistical_bucketizers_used.json"
        );

        const bucketizersRelpath = bucketizersOutput?.relpath;

        if (bucketizersRelpath && typeof bucketizersRelpath === "string") {
          const rawBucketizersResponse = await http.get<any>(
            `/artifacts/${toolId}/${fingerprint}/${bucketizersRelpath}`
          );

          const parsedBucketizersResponse: BucketizersUsedResponse =
            typeof rawBucketizersResponse === "string"
              ? JSON.parse(rawBucketizersResponse)
              : rawBucketizersResponse;

          setBucketizersUsed(parsedBucketizersResponse?.bucketizers ?? null);
        }
      } catch (err: any) {
        setError(err?.message ?? "Failed to load statistical results.");
      } finally {
        setLoading(false);
      }
    }

    loadData();
  }, [toolId, fingerprint, http]);

  if (loading) {
    return <div style={{ padding: 24 }}>Loading statistical results...</div>;
  }

  if (error) {
    return (
      <div style={{ padding: 24, color: "red" }}>
        Error: {error}
      </div>
    );
  }

  
  return (
    <div
      style={{
        padding: 24,
        width: "100%",
        boxSizing: "border-box",
      }}
    >
      <div style={{ marginBottom: "var(--s-5)" }}>
        <h1 style={{ marginTop: 0, marginBottom: 8 }}>Statistical Results</h1>

        <div style={{ display: "flex", gap: 12, flexWrap: "wrap" }}>
          <span className="pill">Run: {fingerprint?.slice(0, 10)}</span>
          <span className="pill">Tool: {toolId}</span>
          <span className="pill">Output: {relpath ?? "n/a"}</span>
          <span className="pill">Rows: {rows.length}</span>
          <span className="pill">Columns: {allColumns.length}</span>
        </div>
      </div>
      <StatisticalKpiGrid
        total={total}
        targetColumns={targetColumns.length}
        avgMaxExcursion={avgMaxExcursion}
        avgBreakoutEfficiency={avgBreakoutEfficiency}
        cleanQuantRate={cleanQuantPct}
      />

      {targetColumns.length > 0 && (
        <div
          style={{
            display: "grid",
            gridTemplateColumns: "repeat(auto-fit, minmax(320px, 1fr))",
            gap: "var(--s-4)",
            marginBottom: 20,
          }}
        >
          {directTargetRateData.length > 0 && (
            <div
              onClick={() =>
                setExpandedChart({
                  title: "Direct Target Success",
                  content: (
                    <StatisticalBarChart
                      title="Direct Target Success"
                      data={directTargetRateData}
                    />
                  ),
                })
              }
              style={{ cursor: "zoom-in" }}
            >
              <StatisticalBarChart
                title="Direct Target Success"
                data={directTargetRateData}
              />
            </div>
          )}

          {atrScanRateData.length > 0 && (
            <div
              onClick={() =>
                setExpandedChart({
                  title: "ATR Scan Success",
                  content: (
                    <StatisticalBarChart
                      title="ATR Scan Success"
                      data={atrScanRateData}
                    />
                  ),
                })
              }
              style={{ cursor: "zoom-in" }}
            >
              <StatisticalBarChart
                title="ATR Scan Success"
                data={atrScanRateData}
              />
            </div>
          )}

          {tickScanRateData.length > 0 && (
            <div
              onClick={() =>
                setExpandedChart({
                  title: "Tick Scan Success",
                  content: (
                    <StatisticalBarChart
                      title="Tick Scan Success"
                      data={tickScanRateData}
                    />
                  ),
                })
              }
              style={{ cursor: "zoom-in" }}
            >
              <StatisticalBarChart
                title="Tick Scan Success"
                data={tickScanRateData}
              />
            </div>
          )}

          {cleanTickRateData.length > 0 && (
            <div
              onClick={() =>
                setExpandedChart({
                  title: "Clean Tick Targets",
                  content: (
                    <StatisticalBarChart
                      title="Clean Tick Targets"
                      data={cleanTickRateData}
                    />
                  ),
                })
              }
              style={{ cursor: "zoom-in" }}
            >
              <StatisticalBarChart
                title="Clean Tick Targets"
                data={cleanTickRateData}
              />
            </div>
          )}

          {cleanQuantSummary !== null && (
            <div
              style={{
                border: "1px solid rgba(255,255,255,0.12)",
                borderRadius: 16,
                padding: 16,
                background: "rgba(255,255,255,0.02)",
              }}
            >
              <h3 style={{ marginTop: 0, marginBottom: 8 }}>Clean Quant</h3>
              <div style={{ fontSize: 32, fontWeight: 800 }}>
                {cleanQuantSummary.toFixed(1)}%
              </div>
              <p style={{ marginBottom: 0, opacity: 0.7, fontSize: 13 }}>
                Quantitative clean-move rate from <code>is_clean_quant</code>.
                This is separate from clean tick target columns.
              </p>
            </div>
          )}
        </div>
      )}

      {bucketizersUsed && Object.keys(bucketizersUsed).length > 0 && (
        <div
          style={{
            border: "1px solid rgba(255,255,255,0.12)",
            borderRadius: 16,
            padding: 16,
            background: "rgba(255,255,255,0.02)",
            marginBottom: 20,
          }}
        >
          <h2 style={{ marginTop: 0, marginBottom: 12 }}>Bucketizers Used</h2>

          {Object.entries(bucketizersUsed)
            .sort(([a], [b]) => sortBucketizerSections(a, b))
            .map(([bucketName, bucketConfig]) => (
              <div key={bucketName} style={{ marginBottom: 12 }}>
                <div style={{ fontWeight: 600, marginBottom: 6 }}>
                  {formatBucketizerLabel(bucketName)}
                </div>

